# Make a copy of this to set environment variables for local development
# cp .env.example .env

# TODO: Fill in auth related env vars
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-here>.databricks.com
# DATABRICKS_TOKEN=dapi....

# TODO: Update with the MLflow experiment you want to log traces and models to
MLFLOW_EXPERIMENT_ID=

# TODO: Update the route to query agent if you used a different port to deploy your agent
API_PROXY=http://localhost:8000/invocations

# App name for Databricks Apps deployment (e.g. my-agent-app)
DBX_APP_NAME=your-app-name

# Foundation Model endpoint name (e.g. claude-sonnet-4-6)
AGENT_MODEL_ENDPOINT=

# Unity Catalog schema (catalog.schema, e.g. my_catalog.my_schema)
PROJECT_UNITY_CATALOG_SCHEMA=

# Genie Space ID (set by create_genie_space.py or create_all_assets.py)
PROJECT_GENIE_CHECKIN=

# Knowledge Assistant endpoint name (set by scripts/ka/create_kas_from_yml.py)
PROJECT_KA_PASSENGERS=

# SQL warehouse ID for UC queries
DATABRICKS_WAREHOUSE_ID=

CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"
